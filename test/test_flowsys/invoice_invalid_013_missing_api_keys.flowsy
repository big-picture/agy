name: Invoice Processing Flow
description: Extract invoice data from PDFs and write to spreadsheet
context_in:
  invoice: Invoice

nodes:
  extract_invoice_data:
    actions:
      - invoice_text = pdf2text(file_path=invoice.pdf_file)
      - invoice_data = extract(input_text=invoice_text, instruction_file="prompts/extract_invoice_data.md", values_to_extract={"invoice_number": "str", "date": "str", "amount": "float", "vat": "float", "party_name": "str"})
      # WRONG: extract() requires API keys (should be detected as warning)
    edges:
      - True: write_to_spreadsheet

  write_to_spreadsheet:
    actions:
      - invoice.add_to_spreadsheet("data/invoices.xlsx")

