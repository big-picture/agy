# OpenAI API Key for LLM calls (classification, extraction, response generation)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-abc123...

# IMAP Server Configuration (for reading emails)
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=your-email@example.com
IMAP_PASSWORD=your-password-or-app-password

# SMTP Server Configuration (for sending emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=465
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-password

# IMAP/SMTP safety (outbound send/reply/forward allowlist)
IMAP_ALLOWED_EMAIL_DOMAINS=example.com,trusted-partner.com
# IMAP_ALLOWED_EMAIL_ADDRESSES=specific@external.com
# IMAP_EMAIL_DRAFT_ONLY=true

# Deprecated global fallbacks (still supported with warning):
# ALLOWED_EMAIL_DOMAINS=...
# ALLOWED_EMAIL_ADDRESSES=...
# EMAIL_DRAFT_ONLY=true
