# OpenAI API Key for LLM calls (classification, extraction, response generation)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-abc123...

# IMAP Server Configuration (for reading emails)
# Host: Your email provider's IMAP server (e.g., imap.gmail.com, imap.outlook.com)
IMAP_HOST=imap.example.com
# Port: Usually 993 for SSL
IMAP_PORT=993
# User: Your email address
IMAP_USER=your-email@example.com
# Password: Your password or App Password (for Gmail: https://myaccount.google.com/apppasswords)
IMAP_PASSWORD=your-password-or-app-password

# SMTP Server Configuration (for sending emails)
# Host: Your email provider's SMTP server (e.g., smtp.gmail.com, smtp.outlook.com)
SMTP_HOST=smtp.example.com
# Port: Usually 465 for SSL, 587 for STARTTLS
SMTP_PORT=465
# User/Password: Optional, defaults to IMAP credentials if not set
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-password

# Safety: Comma-separated list of allowed recipient domains/addresses
# Emails can only be sent to addresses matching these domains or explicit addresses
ALLOWED_EMAIL_DOMAINS=example.com,trusted-partner.com
ALLOWED_EMAIL_ADDRESSES=specific@external.com
