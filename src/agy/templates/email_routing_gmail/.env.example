# OpenAI API Key for LLM calls (classification, extraction, response generation)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-abc123...

# Gmail OAuth Configuration
# Get these from Google Cloud Console: https://console.cloud.google.com

# Auth Mode: Currently only "oauth" is supported
GMAIL_AUTH_MODE=oauth

# Client ID: OAuth 2.0 Client ID
# Create at: Google Cloud Console > APIs & Services > Credentials > Create OAuth Client ID
GMAIL_CLIENT_ID=123456789-abcdefg.apps.googleusercontent.com

# Client Secret: OAuth 2.0 Client Secret
GMAIL_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# Token File: Path to store OAuth tokens after initial authorization
# Will be created automatically on first run (opens browser for authentication)
GMAIL_TOKEN_FILE=.gmail_token.json

# User: Gmail address to access
GMAIL_USER=your-email@gmail.com

# Safety: Comma-separated list of allowed recipient domains/addresses
# Emails can only be sent to addresses matching these domains or explicit addresses
ALLOWED_EMAIL_DOMAINS=gmail.com,yourcompany.com
