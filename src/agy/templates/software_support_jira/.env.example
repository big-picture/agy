# LLM provider key used by classify/respond actions
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx

# Jira connection settings (required by JiraClient.from_env())
JIRA_URL=https://your-company.atlassian.net
JIRA_TOKEN=your_jira_api_token

# Ticket to process (single-ticket workflow)
JIRA_ISSUE_KEY=SUP-123

# Routing configuration
# Transition name used for type x (invalid/misdirected tickets)
JIRA_CLOSE_TRANSITION=Done

# Assignee used for type z (requires specialist handling)
JIRA_ASSIGNEE_A=agent.a
