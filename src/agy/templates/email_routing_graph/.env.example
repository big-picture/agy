# OpenAI API Key for LLM calls (classification, extraction, response generation)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-abc123...

# Microsoft Graph API Configuration
# Get these from Azure Portal: https://portal.azure.com > App registrations

# Tenant ID: Your Azure AD tenant ID (Directory ID)
# Found in: Azure Portal > Azure Active Directory > Overview
TENANT_ID=2dd80b49-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Client ID: Application (client) ID of your registered app
# Found in: Azure Portal > App registrations > Your App > Overview
CLIENT_ID=c189383e-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Client Secret: Secret created for your app registration
# Create at: Azure Portal > App registrations > Your App > Certificates & secrets
CLIENT_SECRET=JZh8Q~xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# User Email: The mailbox to access (user principal name)
USER_EMAIL=support@yourcompany.com

# Safety: Comma-separated list of allowed recipient domains/addresses
# Emails can only be sent to addresses matching these domains or explicit addresses
ALLOWED_EMAIL_DOMAINS=yourcompany.com,partner.com
