# Copy this file to `.env` and fill in your real values.
# Examples:
#   cp .env.example .env
#
# Needed for Jira-based workflows (for example template `software_support_jira`)
JIRA_URL=https://your-company.atlassian.net
JIRA_TOKEN=your_jira_api_token
# Ticket key for single-ticket processing flows
JIRA_ISSUE_KEY=your_jira_issue_key
# Optional for query-based Jira workflows
JIRA_JQL="assignee = \"your.name\""
#
# Needed for model-based workflows/templates
OPENAI_API_KEY=your_openai_api_key
#
# Email (optional): when true, outgoing send/reply/forward are saved as drafts only
# EMAIL_DRAFT_ONLY=true
